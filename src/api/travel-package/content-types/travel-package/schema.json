{
  "kind": "collectionType",
  "collectionName": "travel_packages",
  "info": {
    "singularName": "travel-package",
    "pluralName": "travel-packages",
    "displayName": "Travel Package",
    "description": "Safari and holiday packages"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": ["Safari", "Holiday"],
      "required": true
    },
    "summary": {
      "type": "text",
      "maxLength": 200
    },
    "description": {
      "type": "richtext"
    },
    "duration": {
      "type": "string"
    },
    "maxGroupSize": {
      "type": "integer"
    },
    "minGroupSize": {
      "type": "integer",
      "default": 1
    },
    "difficulty": {
      "type": "enumeration",
      "enum": ["Easy", "Moderate", "Adventurous"]
    },
    "highlights": {
      "type": "component",
      "repeatable": true,
      "component": "shared.package-highlight"
    },
    "included": {
      "type": "richtext"
    },
    "excluded": {
      "type": "richtext"
    },
    "itinerary": {
      "type": "component",
      "repeatable": true,
      "component": "shared.itinerary-day"
    },
    "basePrice": {
      "type": "decimal",
      "required": true
    },
    "discountedPrice": {
      "type": "decimal"
    },
    "currency": {
      "type": "string",
      "default": "INR"
    },
    "inventoryCapacity": {
      "type": "integer"
    },
    "availableDates": {
      "type": "component",
      "repeatable": true,
      "component": "shared.available-date"
    },
    "nationalPark": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::national-park.national-park",
      "inversedBy": "travelPackages"
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "tags": {
      "type": "json"
    },
    "testimonials": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::testimonial.testimonial",
      "mappedBy": "travelPackage"
    },
    "blogs": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::blog.blog",
      "mappedBy": "relatedPackages"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
